<div class="eeb-topbar">
  <div class="eeb-topbar__inner">
    <span>{{ section.settings.top_bar_text | default: '6/51 Prospect Rd, Gaythorne QLD 4051 • 0409 126 669 • hello@everybodyebikes.com.au' }}</span>
  </div>
</div>

<header class="eeb-header">
  <div class="eeb-header__inner">
    <a href="{{ routes.root_url }}" class="eeb-header__logo">
      {% assign header_logo = section.settings.logo | default: settings.logo %}
      {% assign header_logo_width = section.settings.logo_width | default: settings.logo_width | default: 140 %}
      {% if header_logo != blank %}
        <img src="{{ header_logo | image_url: width: 280 }}" width="{{ header_logo.width }}" height="{{ header_logo.height }}" alt="{{ shop.name }}" style="max-width: {{ header_logo_width }}px;">
      {% else %}
        <strong style="font-family: var(--font-heading); font-size: 1.5rem;">{{ shop.name }}</strong>
      {% endif %}
    </a>

    <nav class="eeb-header__nav" aria-label="Primary">
      {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
      {%- elsif section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'link' -%}
            <a href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <a href="/collections/all">E-Bikes &amp; Trikes</a>
        <a href="/collections/accessories">Gear</a>
        <a href="/blogs/news">Experience Hub</a>
        <a href="/pages/contact">Service &amp; Support</a>
        <a href="/pages/dealers">EEB Dealer</a>
      {%- endif -%}
    </nav>

    <div class="eeb-header__actions">
      <a href="{{ routes.cart_url }}" aria-label="Cart">
        {% render 'icon', icon: 'cart', size: 22 %}
      </a>
      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_url | default: '#' }}" class="eeb-btn eeb-btn--primary" style="padding: .5rem 1rem; font-size: .85rem;">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>
  </div>
</header>

{% schema %}
{
  "name": "EEB Header",
  "tag": "section",
  "class": "shopify-section-header-eeb",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo override (optional)" },
    { "type": "range", "id": "logo_width", "min": 60, "max": 240, "step": 10, "unit": "px", "label": "Logo width override", "default": 140 },
    { "type": "text", "id": "top_bar_text", "label": "Top contact bar text", "default": "6/51 Prospect Rd, Gaythorne QLD 4051 • 0409 126 669 • hello@everybodyebikes.com.au" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu (overrides blocks)" },
    { "type": "text", "id": "cta_text", "label": "CTA button text", "default": "Find a Dealer" },
    { "type": "url", "id": "cta_url", "label": "CTA button URL" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Link" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "link", "settings": { "label": "E-Bikes & Trikes" } },
        { "type": "link", "settings": { "label": "Gear" } },
        { "type": "link", "settings": { "label": "Experience Hub" } },
        { "type": "link", "settings": { "label": "Service & Support" } },
        { "type": "link", "settings": { "label": "EEB Dealer" } }
      ]
    }
  ]
}
{% endschema %}
