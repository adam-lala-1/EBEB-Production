<section class="eeb-section">
  <div class="eeb-container">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}<p style="color:var(--color-muted);max-width:640px;">{{ collection.description }}</p>{%- endif -%}
    <div class="eeb-grid eeb-grid--3" style="margin-top:2rem;">
      {%- for product in collection.products -%}
        <a href="{{ product.url }}" class="eeb-card">
          <div class="eeb-card__img">{% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="lazy">{% endif %}</div>
          <div class="eeb-card__body">
            <h3>{{ product.title }}</h3>
            <p>{{ product.price | money }}</p>
          </div>
        </a>
      {%- else -%}
        <p>No products in this collection yet.</p>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}<div style="margin-top:2rem;">{{ paginate | default_pagination }}</div>{%- endif -%}
  </div>
</section>

{% schema %}
{ "name": "Collection main", "settings": [], "presets": [{ "name": "Collection main" }] }
{% endschema %}
