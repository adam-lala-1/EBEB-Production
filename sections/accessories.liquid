<section class="eeb-section eeb-section--cream">
  <div class="eeb-container">
    <div style="text-align:center;margin-bottom:3rem;">
      {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="eeb-grid eeb-grid--4">
      {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
        {%- for product in section.settings.collection.products limit: 8 -%}
          <a href="{{ product.url }}" class="eeb-card">
            <div class="eeb-card__img">{% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">{% endif %}</div>
            <div class="eeb-card__body"><h3>{{ product.title }}</h3><p>{{ product.price | money }}</p></div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          <a href="{{ block.settings.link | default: '#' }}" class="eeb-card" {{ block.shopify_attributes }}>
            <div class="eeb-card__img">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" loading="lazy" style="object-fit:contain;background:#fff;padding:1rem;">
              {% elsif block.settings.image_url != blank %}
                <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" style="object-fit:contain;background:#fff;padding:1rem;">
              {% endif %}
            </div>
            <div class="eeb-card__body"><h3>{{ block.settings.title }}</h3><p>{{ block.settings.price }}</p></div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Accessories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Gear up" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Accessories" },
    { "type": "collection", "id": "collection", "label": "Accessories collection" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Manual item (fallback)",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Or image URL (fallback)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Accessory" },
        { "type": "text", "id": "price", "label": "Price", "default": "$0.00" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Accessories",
      "blocks": [
        { "type": "item", "settings": { "title": "Abus 8808C Lock", "price": "$240.00", "image_url": "https://everybodyebikes.com.au/cdn/shop/files/Screenshot2025-11-05163537.png?v=1762324582&width=1445" } },
        { "type": "item", "settings": { "title": "Adaptive Accessories", "price": "Various", "image_url": "https://everybodyebikes.com.au/cdn/shop/files/1000007372_5e24f5b1-faaf-42f0-a6c7-2b2ca708efdb.png?v=1765257110&width=1445" } },
        { "type": "item", "settings": { "title": "Vamos Amigo", "price": "from $4,345", "image_url": "https://everybodyebikes.com.au/cdn/shop/files/Red_Vamos_Bike.png?v=1740544801&width=1445" } },
        { "type": "item", "settings": { "title": "Kalkhoff Endeavour", "price": "from $3,950", "image_url": "https://everybodyebikes.com.au/cdn/shop/files/Screenshot2024-01-09120138.png?v=1704765964&width=1445" } }
      ]
    }
  ]
}
{% endschema %}
