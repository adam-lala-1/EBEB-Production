<section class="eeb-section eeb-section--navy eeb-series">
  <div class="eeb-container">
    <div class="eeb-series__header">
      <div>
        {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow eeb-eyebrow--light">{{ section.settings.eyebrow }}</span>{% endif %}
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.subtext != blank %}<p class="eeb-series__subtext">{{ section.settings.subtext }}</p>{% endif %}
      </div>
      {% if section.settings.cta_text != blank %}
        <a href="{{ section.settings.cta_url | default: '#' }}" class="eeb-btn eeb-btn--ghost">{{ section.settings.cta_text }}</a>
      {% endif %}
    </div>

    {%- comment -%} Build a unified array of cards from collection or blocks {%- endcomment -%}
    {%- assign use_collection = false -%}
    {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
      {%- assign use_collection = true -%}
    {%- endif -%}

    {%- if use_collection -%}
      {%- assign products = section.settings.collection.products -%}
      {%- assign featured = products[0] -%}

      <a href="{{ featured.url }}" class="eeb-series__featured">
        <div class="eeb-series__featured-img">
          {% if featured.featured_image %}<img src="{{ featured.featured_image | image_url: width: 1200 }}" alt="{{ featured.title | escape }}" loading="lazy">{% endif %}
        </div>
        <div class="eeb-series__featured-body">
          {% if featured.type != blank %}<span class="eeb-card__eyebrow">{{ featured.type }}</span>{% endif %}
          <h3>{{ featured.title }}</h3>
          <p class="eeb-series__price">from {{ featured.price_min | money }}</p>
          {% if featured.description != blank %}<p class="eeb-series__desc">{{ featured.description | strip_html | truncate: 200 }}</p>{% endif %}
          <span class="eeb-btn eeb-btn--primary">Enquire Now →</span>
        </div>
      </a>

      {%- if products.size > 1 -%}
        <div class="eeb-grid eeb-grid--2 eeb-series__secondary">
          {%- for product in products offset: 1 limit: 2 -%}
            <a href="{{ product.url }}" class="eeb-card">
              <div class="eeb-card__img" style="background:#f8f5f0;">
                {% if product.featured_image %}<img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" loading="lazy" style="object-fit:contain;padding:1rem;">{% endif %}
              </div>
              <div class="eeb-card__body">
                {% if product.type != blank %}<span class="eeb-card__eyebrow">{{ product.type }}</span>{% endif %}
                <h3>{{ product.title }}</h3>
                <p class="eeb-series__price-sm">from {{ product.price_min | money }}</p>
                {% if product.description != blank %}<p>{{ product.description | strip_html | truncate: 110 }}</p>{% endif %}
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}

    {%- else -%}
      {%- assign first_block = section.blocks[0] -%}
      {% if first_block %}
        <a href="{{ first_block.settings.link | default: '#' }}" class="eeb-series__featured" {{ first_block.shopify_attributes }}>
          <div class="eeb-series__featured-img">
            {% if first_block.settings.image != blank %}
              <img src="{{ first_block.settings.image | image_url: width: 1200 }}" alt="{{ first_block.settings.title | escape }}" loading="lazy">
            {% elsif first_block.settings.image_url != blank %}
              <img src="{{ first_block.settings.image_url }}" alt="{{ first_block.settings.title | escape }}" loading="lazy">
            {% endif %}
          </div>
          <div class="eeb-series__featured-body">
            {% if first_block.settings.subtitle != blank %}<span class="eeb-card__eyebrow">{{ first_block.settings.subtitle }}</span>{% endif %}
            <h3>{{ first_block.settings.title }}</h3>
            {% if first_block.settings.price != blank %}<p class="eeb-series__price">{{ first_block.settings.price }}</p>{% endif %}
            {% if first_block.settings.description != blank %}<p class="eeb-series__desc">{{ first_block.settings.description }}</p>{% endif %}
            {%- if first_block.settings.specs != blank -%}
              {%- assign specs = first_block.settings.specs | split: ';' -%}
              <ul class="eeb-card__list">
                {%- for spec in specs -%}<li>{{ spec | strip }}</li>{%- endfor -%}
              </ul>
            {%- endif -%}
            <span class="eeb-btn eeb-btn--primary">Enquire Now →</span>
          </div>
        </a>
      {% endif %}

      {%- if section.blocks.size > 1 -%}
        <div class="eeb-grid eeb-grid--2 eeb-series__secondary">
          {%- for block in section.blocks offset: 1 limit: 2 -%}
            <a href="{{ block.settings.link | default: '#' }}" class="eeb-card" {{ block.shopify_attributes }}>
              <div class="eeb-card__img" style="background:#f8f5f0;">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy" style="object-fit:contain;padding:1rem;">
                {% elsif block.settings.image_url != blank %}
                  <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" style="object-fit:contain;padding:1rem;">
                {% endif %}
              </div>
              <div class="eeb-card__body">
                {% if block.settings.subtitle != blank %}<span class="eeb-card__eyebrow">{{ block.settings.subtitle }}</span>{% endif %}
                <h3>{{ block.settings.title }}</h3>
                {% if block.settings.price != blank %}<p class="eeb-series__price-sm">{{ block.settings.price }}</p>{% endif %}
                {% if block.settings.description != blank %}<p>{{ block.settings.description }}</p>{% endif %}
              </div>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "EEB Series",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Inclusive Engineering by EEB" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The EEB Series" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Engineered in-house, built for every body. Our signature range of electric trikes and bikes — inclusively engineered and available through our dealer network." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Become a Dealer" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "header", "content": "Products" },
    { "type": "paragraph", "content": "Pick a collection to auto-populate the first 3 products, OR add manual blocks below." },
    { "type": "collection", "id": "collection", "label": "Collection (optional)" }
  ],
  "blocks": [
    {
      "type": "manual_card",
      "name": "Manual card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Or image URL (fallback)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Trident" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Semi-Recumbent Electric Trike" },
        { "type": "text", "id": "price", "label": "Price", "default": "from $4,995" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "specs", "label": "Specs (semicolon separated, featured card only)", "default": "80km Range; Semi-Recumbent; 25km/h Assist" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "EEB Series",
      "blocks": [
        {
          "type": "manual_card",
          "settings": {
            "title": "Trident",
            "subtitle": "Semi-Recumbent Electric Trike",
            "price": "from $4,995",
            "description": "Unmatched stability meets premium performance. Built for riders who demand comfort, confidence, and range.",
            "specs": "80km Range; Semi-Recumbent; 25km/h Assist",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/Screenshot2024-01-10151536.png?v=1704863800&width=1445"
          }
        },
        {
          "type": "manual_card",
          "settings": {
            "title": "Trojan",
            "subtitle": "Fat Tyre Electric Trike",
            "price": "from $3,495",
            "description": "Agile, powerful, and ready for family adventures and daily rides.",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/IMG_1997.jpg?v=1762408959&width=1445"
          }
        },
        {
          "type": "manual_card",
          "settings": {
            "title": "Lightning",
            "subtitle": "Folding Electric Bike",
            "price": "from $2,495",
            "description": "Compact, fast-folding, and ready to go anywhere life takes you.",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/Screenshot2024-01-09120138.png?v=1704765964&width=1445"
          }
        }
      ]
    }
  ]
}
{% endschema %}
