<section class="eeb-section eeb-section--navy" style="text-align:center;">
  <div class="eeb-container" style="max-width: 720px;">
    <h2>{{ section.settings.heading }}</h2>
    <p style="opacity:.8;margin-bottom:2rem;">{{ section.settings.subheading }}</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      {% if section.settings.cta1_text != blank %}<a class="eeb-btn eeb-btn--primary" href="{{ section.settings.cta1_url }}">{{ section.settings.cta1_text }}</a>{% endif %}
      {% if section.settings.cta2_text != blank %}<a class="eeb-btn eeb-btn--ghost" href="{{ section.settings.cta2_url }}">{{ section.settings.cta2_text }}</a>{% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA banner",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find your nearest dealer" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Test ride an EEB at one of our partner stores around Australia." },
    { "type": "text", "id": "cta1_text", "label": "Primary CTA text", "default": "Book a Test Ride" },
    { "type": "url", "id": "cta1_url", "label": "Primary CTA URL" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA text", "default": "Find a Dealer" },
    { "type": "url", "id": "cta2_url", "label": "Secondary CTA URL" }
  ],
  "presets": [{ "name": "CTA banner" }]
}
{% endschema %}
