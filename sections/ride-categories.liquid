<section class="eeb-section eeb-section--cream">
  <div class="eeb-container" style="text-align:center;">
    {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}<p style="max-width:640px;margin:0 auto 3rem;color:var(--color-muted);">{{ section.settings.subheading }}</p>{% endif %}

    <div class="eeb-grid eeb-grid--3">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="eeb-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="eeb-card__img"><img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy"></div>
          {% endif %}
          <div class="eeb-card__body">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ride categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find your ride" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ride categories" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Step-Through" },
        { "type": "text", "id": "description", "label": "Description", "default": "Easy on, easy off." },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{ "name": "Ride categories", "blocks": [ { "type": "category" }, { "type": "category" }, { "type": "category" } ] }]
}
{% endschema %}
