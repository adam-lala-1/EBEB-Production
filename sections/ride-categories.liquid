<section class="eeb-section eeb-section--cream">
  <div class="eeb-container" style="text-align:center;">
    {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.subheading != blank %}<p style="max-width:640px;margin:0 auto 3rem;color:var(--color-muted);">{{ section.settings.subheading }}</p>{% endif %}

    <div class="eeb-grid eeb-grid--3">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="eeb-card" {{ block.shopify_attributes }}>
          <div class="eeb-card__img">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% elsif block.settings.image_url != blank %}
              <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {% endif %}
          </div>
          <div class="eeb-card__body">
            {% if block.settings.eyebrow != blank %}<span class="eeb-card__eyebrow">{{ block.settings.eyebrow }}</span>{% endif %}
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
            {%- if block.settings.features != blank -%}
              {%- assign features = block.settings.features | split: ';' -%}
              <ul class="eeb-card__list">
                {%- for feature in features -%}<li>{{ feature | strip }}</li>{%- endfor -%}
              </ul>
            {%- endif -%}
            <span class="eeb-btn eeb-btn--dark">Explore</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ride categories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Find your ride" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Ride categories" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_url", "label": "Or image URL (fallback)" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Let us ride together" },
        { "type": "text", "id": "title", "label": "Title", "default": "Urban & Families" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Cargo e-bikes built for the whole family." },
        { "type": "text", "id": "features", "label": "Features (semicolon separated)", "default": "Child-safe seating; Up to 200kg payload; Weather canopies" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Ride categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Urban & Families",
            "eyebrow": "Let us ride together",
            "description": "Carry the kids, the groceries, or the dog. Cargo e-bikes built for the whole family.",
            "features": "Child-safe seating options; Up to 200kg payload; Weather canopies available",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/1000013384.jpg?v=1762408406&width=1445"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Seniors",
            "eyebrow": "Keep riding",
            "description": "Step-through frames, comfortable seats, and electric assist that makes every ride effortless.",
            "features": "Step-through easy mount; Electric assist up to 25km/h; Stable trike options",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/1000018005.jpg?v=1766459780&width=1445"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Inclusive Mobility",
            "eyebrow": "Adaptive freedom",
            "description": "NDIS approved e-trikes and adaptive solutions designed for every ability.",
            "features": "NDIS approved options; Custom adaptive setups; Harnesses & supports",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/IMG_2044.jpg?v=1762408443&width=1445"
          }
        }
      ]
    }
  ]
}
{% endschema %}
