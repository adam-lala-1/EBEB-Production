{%- assign fallback_image = 'https://everybodyebikes.com.au/cdn/shop/files/IMG_1997.jpg?v=1762408959&width=1920' -%}
<section class="eeb-section">
  <div class="eeb-container">
    <div class="eeb-imgtext {% if section.settings.image_position == 'right' %}eeb-imgtext--reverse{% endif %}">
      <div>
        {% if section.settings.image != blank %}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | escape }}" loading="lazy">
        {% else %}
          <img src="{{ fallback_image }}" alt="Family riding together on electric trikes" loading="lazy">
        {% endif %}
      </div>
      <div>
        {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
        <h2>{{ section.settings.heading }}</h2>
        <div>{{ section.settings.body | default: '<p>From family adventures to daily commutes, our inclusive engineering is designed to keep people moving together for the long haul.</p>' }}</div>
        <a class="eeb-btn eeb-btn--dark" href="{{ section.settings.cta_url | default: '/pages/dealers' }}" style="margin-top:1rem;">{{ section.settings.cta_text | default: 'Enquire and Try' }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero (Alt)",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [ {"value":"left","label":"Left"}, {"value":"right","label":"Right"} ] },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Engineered for the long haul." },
    { "type": "richtext", "id": "body", "label": "Body" },
    { "type": "text", "id": "cta_text", "label": "CTA text" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Hero (Alt)" }]
}
{% endschema %}
