<section class="eeb-section">
  <div class="eeb-container">
    <div class="eeb-imgtext {% if section.settings.image_position == 'right' %}eeb-imgtext--reverse{% endif %}">
      <div>{% if section.settings.image != blank %}<img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" loading="lazy">{% endif %}</div>
      <div>
        <h2>{{ section.settings.heading }}</h2>
        <p style="color: var(--color-muted); margin-bottom: 1rem;">{{ section.settings.body }}</p>
        <ul>
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trident feature block",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "default": "left", "options": [ {"value":"left","label":"Left"}, {"value":"right","label":"Right"} ] },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stability & Comfort" },
    { "type": "textarea", "id": "body", "label": "Body" }
  ],
  "blocks": [
    { "type": "bullet", "name": "Bullet", "settings": [ { "type": "text", "id": "text", "label": "Text" } ] }
  ],
  "presets": [{ "name": "Trident feature block" }]
}
{% endschema %}
