<section class="eeb-section eeb-section--cream">
  <div class="eeb-container">
    <div style="text-align:center;margin-bottom:3rem;">
      {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="eeb-grid eeb-grid--3">
      {%- for block in section.blocks -%}
        <article class="eeb-card" {{ block.shopify_attributes }}>
          <div class="eeb-card__img">
            {% if block.settings.image != blank %}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {% elsif block.settings.image_url != blank %}
              <img src="{{ block.settings.image_url }}" alt="{{ block.settings.name | escape }}" loading="lazy">
            {% endif %}
          </div>
          <div class="eeb-card__body">
            <h3>{{ block.settings.name }}</h3>
            <p style="font-style:italic;color:var(--color-foreground);margin-bottom:.5rem;">"{{ block.settings.quote }}"</p>
            <p style="font-size:.85rem;color:var(--color-orange);font-weight:600;">{{ block.settings.bike }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ride stories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ride stories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real riders, real freedom" }
  ],
  "blocks": [
    {
      "type": "story",
      "name": "Story",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Photo" },
        { "type": "text", "id": "image_url", "label": "Or image URL (fallback)" },
        { "type": "text", "id": "name", "label": "Rider name", "default": "Rider name" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "An inspiring rider quote." },
        { "type": "text", "id": "bike", "label": "Bike model", "default": "EEB Bike" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Ride stories",
      "blocks": [
        {
          "type": "story",
          "settings": {
            "name": "The School Run Family",
            "quote": "Our morning school run went from stressful chaos to the best part of our day.",
            "bike": "Trojan Family Trike",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/1000013384.jpg?v=1762408406&width=1445"
          }
        },
        {
          "type": "story",
          "settings": {
            "name": "Active at 72",
            "quote": "The Trident gave me my independence back — I ride to the shops, the park, everywhere.",
            "bike": "Trident Semi-Recumbent",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/Screenshot2024-01-10151536.png?v=1704863800&width=1445"
          }
        },
        {
          "type": "story",
          "settings": {
            "name": "Adaptive Freedom",
            "quote": "For the first time in years, I can ride alongside my family.",
            "bike": "Custom Adapted Trike",
            "image_url": "https://everybodyebikes.com.au/cdn/shop/files/1000007372_5e24f5b1-faaf-42f0-a6c7-2b2ca708efdb.png?v=1765257110&width=1445"
          }
        }
      ]
    }
  ]
}
{% endschema %}
