<section class="eeb-hero">
  <div class="eeb-hero__bg">
    {% if section.settings.image != blank %}
      <img src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.image.alt | escape }}" loading="eager">
    {% endif %}
  </div>
  <div class="eeb-hero__content">
    {% if section.settings.eyebrow != blank %}<span class="eeb-eyebrow" style="color: var(--color-orange);">{{ section.settings.eyebrow }}</span>{% endif %}
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    {% if section.settings.cta_text != blank %}
      <a class="eeb-btn eeb-btn--primary" href="{{ section.settings.cta_url }}">{{ section.settings.cta_text }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Mobility, redefined" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "An eBike for every body." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Inclusive electric bikes & trikes designed for freedom, comfort, and confidence." },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Explore the Range" },
    { "type": "url", "id": "cta_url", "label": "CTA URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
