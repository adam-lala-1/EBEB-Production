<section class="eeb-hero" data-eeb-hero>
  <div class="eeb-container">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="eeb-hero__slide{% if forloop.first %} is-active{% endif %}"{% unless forloop.first %} hidden{% endunless %} data-eeb-hero-slide {{ block.shopify_attributes }}>
          <div class="eeb-hero__panel">
            <div class="eeb-hero__copy">
              {% if block.settings.eyebrow != blank %}<span class="eeb-eyebrow">{{ block.settings.eyebrow }}</span>{% endif %}
              <h1>{{ block.settings.heading }} {% if block.settings.heading_highlight != blank %}<span class="eeb-hero__highlight">{{ block.settings.heading_highlight }}</span>{% endif %}</h1>
              <p>{{ block.settings.body }}</p>
              {% if block.settings.cta_text != blank %}
                <a class="eeb-btn eeb-btn--primary" href="{{ block.settings.cta_url | default: '#' }}">{{ block.settings.cta_text }}</a>
              {% endif %}
              <div class="eeb-hero__controls">
                <button class="eeb-hero__nav" type="button" aria-label="Previous slide" data-eeb-hero-prev>
                  <span aria-hidden="true">&#8592;</span>
                </button>
                <div class="eeb-hero__dots" aria-label="Hero slides">
                  {%- for dot_block in section.blocks -%}
                    <button class="eeb-hero__dot{% if forloop.index0 == 0 %} is-active{% endif %}" type="button" aria-label="Go to slide {{ forloop.index }}" data-eeb-hero-dot data-index="{{ forloop.index0 }}"></button>
                  {%- endfor -%}
                </div>
                <button class="eeb-hero__nav" type="button" aria-label="Next slide" data-eeb-hero-next>
                  <span aria-hidden="true">&#8594;</span>
                </button>
              </div>
              {%- if section.settings.show_badges -%}
                <div class="eeb-hero__badges">
                  {% if section.settings.badge_1 != blank %}<span class="eeb-hero__badge">{{ section.settings.badge_1 }}</span>{% endif %}
                  {% if section.settings.badge_2 != blank %}<span class="eeb-hero__badge">{{ section.settings.badge_2 }}</span>{% endif %}
                  {% if section.settings.badge_3 != blank %}<span class="eeb-hero__badge">{{ section.settings.badge_3 }}</span>{% endif %}
                </div>
              {%- endif -%}
            </div>
            <div class="eeb-hero__media">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.image.alt | escape }}" loading="eager">
              {% elsif block.settings.image_url != blank %}
                <img src="{{ block.settings.image_url }}" alt="{{ block.settings.heading | escape }}" loading="eager">
              {% endif %}
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

<script>
  (() => {
    const hero = document.currentScript.previousElementSibling;
    if (!hero || hero.dataset.eebHeroBound === 'true') return;
    hero.dataset.eebHeroBound = 'true';

    const slides = Array.from(hero.querySelectorAll('[data-eeb-hero-slide]'));
    const dots = Array.from(hero.querySelectorAll('[data-eeb-hero-dot]'));
    const prev = hero.querySelector('[data-eeb-hero-prev]');
    const next = hero.querySelector('[data-eeb-hero-next]');
    if (!slides.length) return;

    let current = 0;
    let timer;

    const render = (index) => {
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => {
        const active = i === current;
        slide.classList.toggle('is-active', active);
        slide.hidden = !active;
      });
      dots.forEach((dot, i) => dot.classList.toggle('is-active', i === current));
    };

    const restart = () => {
      window.clearInterval(timer);
      timer = window.setInterval(() => render(current + 1), 6000);
    };

    prev && prev.addEventListener('click', () => { render(current - 1); restart(); });
    next && next.addEventListener('click', () => { render(current + 1); restart(); });
    dots.forEach((dot, i) => dot.addEventListener('click', () => { render(i); restart(); }));
    render(0);
    restart();
  })();
</script>

